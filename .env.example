# ── GitHub OAuth App（https://github.com/settings/developers → New OAuth App）──
# Homepage URL:            https://note.sisihome.org      （本機開發用 http://localhost:3210）
# Authorization callback:  https://note.sisihome.org/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 對外網址（OAuth redirect 與分享連結都用它）
BASE_URL=http://localhost:3210

# session token 加密金鑰（未設定會自動產生並存在 data/.secret）
SECRET=

# 本機開發便利：填一把 PAT 可跳過 OAuth（正式環境不要設）
DEV_PAT=

# 匿名訪客讀 public repo 的後備 token（提高 rate limit 用，可留空）
GITHUB_FALLBACK_TOKEN=

PORT=3210
